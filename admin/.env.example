# Backend origin only (no /api). Must match your deployed API URL on Render.
# Example: https://api.visavo.in
VITE_API_URL=https://api.visavo.in

# Public site origin (no trailing slash). “Open live page” in blog body preview links here.
# Example: https://www.yoursite.com
VITE_PUBLIC_CLIENT_URL=http://localhost:5173
