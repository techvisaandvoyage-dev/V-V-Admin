# Copy to .env — backend where Express runs (same as server PORT, default 5000).
# Do not include /api; the app appends it automatically.
# Production example: https://api.visavo.in
VITE_API_URL=http://localhost:5000

# Production: full origin of the admin app (Cloudflare Pages .pages.dev or custom domain).
# Example after admin deploy: https://www.admin.visavo.in
# VITE_ADMIN_APP_ORIGIN=https://www.admin.visavo.in
